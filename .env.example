FMP_API_KEY=your_key_here

# Set to "true" to pause all autonomous FMP API calls (initial universe build,
# 5-minute incremental refresh, and catalyst warm on startup). Use when the
# FMP quota is exhausted; on-demand API routes still work off the existing
# cache. Unset (or set to anything else) to resume normal background traffic.
PAUSE_FMP_BACKGROUND=true
